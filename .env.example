# Gum 백엔드 베이스 URL(import.meta.env.VITE_GUM_SERVER_URL). 프로토콜+호스트만; trailing / 있어도 됨(code에서 제거함).
# 원격 예시 — 로컬 .env 또는 .env.local 에 복사해 사용 가능
VITE_GUM_SERVER_URL=https://gum-server.onrender.com

# 로컬 Gum 서버: 아래처럼 지정하거나, 변수를 비우면 Vite 오리진(:5173)으로 나가므로 vite.config.js 의 /api 프록시가 적용됨
# VITE_GUM_SERVER_URL=http://localhost:3000
